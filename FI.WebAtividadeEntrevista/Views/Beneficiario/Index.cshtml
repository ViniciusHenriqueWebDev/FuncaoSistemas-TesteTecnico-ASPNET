<div class="modal fade" id="modalBeneficiarios" tabindex="-1" role="dialog" aria-labelledby="modalBeneficiariosLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close pull-right" data-dismiss="modal" aria-label="Fechar" style="margin-top:2px;">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title" id="modalBeneficiariosLabel">Beneficiários</h4>
            </div>
            <div class="modal-body">
                <div class="form-row align-items-center mb-3" style="display: flex; flex-wrap: wrap;">
                    <div class="form-group mb-0" style="min-width: 180px; margin-right: 20px;">
                        <label for="BeneficiarioCPF" class="mb-0"><strong>CPF:</strong></label>
                        <input type="text" class="form-control" id="BeneficiarioCPF" name="BeneficiarioCPF" placeholder="Ex.: 010.011.111-00" maxlength="14" style="width: 180px;" required>
                    </div>
                    <div class="form-group mb-0" style="min-width: 200px; margin-right: 10px;">
                        <label for="BeneficiarioNome" class="mb-0"><strong>Nome:</strong></label>
                        <input type="text" class="form-control" id="BeneficiarioNome" name="BeneficiarioNome" placeholder="Ex.: Maria" maxlength="50" style="width: 200px;" required>
                    </div>
                    <div class="form-group mb-0" style="align-self: flex-end;">
                        <button type="button" class="btn btn-success" id="btnAdicionarBeneficiario" style="margin-top: 24px;">Incluir</button>
                    </div>
                    <div id="msgBeneficiario" class="text-danger" style="margin-bottom:10px;"></div>
                </div>
                <div class="row mt-2">
                    <div class="col-md-12">
                        <table class="table" id="gridBeneficiarios" style="margin-bottom: 0;">
                            <thead>
                                <tr>
                                    <th>CPF</th>
                                    <th>Nome</th>
                                    <th style="width: 160px;">Açőes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Linhas adicionadas via JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>